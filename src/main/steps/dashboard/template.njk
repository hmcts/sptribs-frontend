{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% extends "common/page.njk" %}

{% block backLink %}{% endblock %}

{% block page_content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        {% if caseNumber %}
          {{ govukPanel({
              titleText: userFullName,
              html: "<strong>" + caseNumber + "</strong>"
              }) }}
        {% endif %}

        <h2 class="govuk-heading-m govuk-!-margin-top-6">{{ documentsHeading }}</h2>

        {% if hasDocuments %}

          {% if contactPartiesDocuments.length > 0 %}

            {% set tableRows = [] %}

            {% for document in contactPartiesDocuments %}

              {% set documentNameHtml %}
                {% if document.downloaded %}
                  {{ govukTag({
                    text: downloadedTag,
                    classes: "govuk-tag--grey govuk-!-margin-right-2 document-tag"
                  }) }}
                {% else %}
                  {{ govukTag({
                    text: newTag,
                    classes: "govuk-tag--green govuk-!-margin-right-2 document-tag"
                  }) }}
                {% endif %}
                {{ document.name }}
              {% endset %}

              {% set statusTag %}
                {% if document.isLatest %}
                  {{ govukTag({
                      text: latestTag,
                      classes: "govuk-tag--blue"
                  }) }}
                {% endif %}
              {% endset %}

              {% set downloadLink %}
                <a class="govuk-link download-link" href="{{ document.downloadUrl | escape }}" download="{{ document.name | escape }}" data-downloaded-text="{{ downloadedTag }}">
                  {{ download }}
                </a>
              {% endset %}

              {% set tableRows = (tableRows.push([
                {
                  html: documentNameHtml
                }, {
                  text: document.date
                }, {
                  html: statusTag
                }, {
                  html: downloadLink
                }
              ]), tableRows) %}

            {% endfor %}

            {{ govukTable({
                head: [
                {
                text: documentName
                },
                {
                text: date
                },
                {
                text: status
                },
                {
                text: action
                }
                ],
                rows: tableRows
            }) }}

          {% endif %}

          {% if orderAndDecisionDocuments.length > 0 %}

            <h3 class="govuk-heading-m govuk-!-margin-top-6">Orders and decisions</h3>

            {% set tableRows = [] %}

            {% for document in orderAndDecisionDocuments %}

              {% set documentNameHtml %}
                {% if document.downloaded %}
                  {{ govukTag({
                    text: downloadedTag,
                    classes: "govuk-tag--grey govuk-!-margin-right-2 document-tag"
                  }) }}
                {% else %}
                  {{ govukTag({
                    text: newTag,
                    classes: "govuk-tag--green govuk-!-margin-right-2 document-tag"
                  }) }}
                {% endif %}
                {{ document.name }}
              {% endset %}

              {% set statusTag %}
                {% if document.isLatest %}
                  {{ govukTag({
                    text: latestTag,
                    classes: "govuk-tag--blue"
                  }) }}
                {% endif %}
              {% endset %}

              {% set downloadLink %}
                <a class="govuk-link download-link" href="{{ document.downloadUrl | escape }}" download="{{ document.name | escape }}" data-downloaded-text="{{ downloadedTag }}">
                  {{ download }}
                </a>
              {% endset %}

              {% set tableRows = (tableRows.push([
                {
                  html: documentNameHtml
                }, {
                  text: document.date
                }, {
                  html: statusTag
                }, {
                  html: downloadLink
                }
              ]), tableRows) %}

            {% endfor %}

            {{ govukTable({
                head: [
                {
                text: documentName
                },
                {
                text: date
                },
                {
                text: status
                },
                {
                text: action
                }
                ],
                rows: tableRows
            }) }}

          {% endif %}

          {% if latestCaseBundleDocuments.length > 0 %}

            <h3 class="govuk-heading-m govuk-!-margin-top-6">Latest appeal bundle documents</h3>

            {% set document = latestCaseBundleDocuments[0] %}

            {% set documentNameHtml %}
              {% if document.downloaded %}
                {{ govukTag({
                  text: downloadedTag,
                  classes: "govuk-tag--grey govuk-!-margin-right-2 document-tag"
                }) }}
              {% else %}
                {{ govukTag({
                  text: newTag,
                  classes: "govuk-tag--green govuk-!-margin-right-2 document-tag"
                }) }}
              {% endif %}
              {{ document.name }}
            {% endset %}

            {% set statusTag %}
              {% if document.isLatest %}
                {{ govukTag({
                    text: latestTag,
                    classes: "govuk-tag--blue"
                }) }}
              {% endif %}
            {% endset %}

            {% set downloadLink %}
              <a class="govuk-link download-link" href="{{ document.downloadUrl | escape }}" download="{{ document.name | escape }}" data-downloaded-text="{{ downloadedTag }}">
                {{ download }}
              </a>
            {% endset %}

            {% set tableRows = [
              [
                {
                  html: documentNameHtml
                }, {
                  text: document.date
                }, {
                  html: statusTag
                }, {
                  html: downloadLink
                }
              ]
            ] %}

            {{ govukTable({
                head: [
                {
                text: documentName
                },
                {
                text: date
                },
                {
                text: status
                },
                {
                text: action
                }
                ],
                rows: tableRows
            }) }}

          {% endif %}

        {% else %}

          {{ govukInsetText({
              text: noDocumentsMessage
          }) }}

        {% endif %}

      </div>
    </div>
  </div>

  <script type="text/javascript">
    (function() {
      document.querySelectorAll('.download-link').forEach(function(link) {
        link.addEventListener('click', function() {
          var row = link.closest('tr');
          if (row) {
            var tag = row.querySelector('.document-tag');
            if (tag && tag.classList.contains('govuk-tag--green')) {
              tag.classList.remove('govuk-tag--green');
              tag.classList.add('govuk-tag--grey');
              tag.textContent = link.getAttribute('data-downloaded-text') || 'Downloaded';
            }
          }
        });
      });
    })();
  </script>
{% endblock %}
